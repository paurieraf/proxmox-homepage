- Infrastructura i xarxa:
    - Infrastructura:
        - Proxmox:
            icon: sh-proxmox
            href: https://${DOMAIN_PVE}
            description: Proxmox Virtualization Platform
            widget:
              type: proxmox
              url: https://${DOMAIN_PVE}
              username: ${PROXMOX_NODE_USERNAME}
              password: ${PROXMOX_NODE_PASSWORD}
              node: ${PROXMOX_NODE_NAME}

        - ProxMenux:
            icon: sh-proxmenux
            href: https://${DOMAIN_PROXMENUX}
            description: Otro PVE monitor

        - Netdata:
            icon: si-netdata
            href: https://${DOMAIN_NETDATA}
            description: PVE monitor
            widget:
              type: netdata
              url: https://${DOMAIN_NETDATA}

    - Xarxa:
