        - Cloudflare Tunnel:
            icon: sh-cloudflare
            href: https://dash.cloudflare.com/
            description: Ramper web túnel
            widget:
              type: cloudflared
              accountid: ${CLOUDFLARE_ACCOUNT_ID}
              tunnelid: ${CLOUDFLARE_TUNNEL_ID}
              key: ${CLOUDFLARE_TUNNEL_KEY}

